# tower control plane
PORT=4000
HOST=127.0.0.1

# controlplane DB — direct :5432 (provisioning runs CREATE DATABASE, which
# cannot run through PgBouncer transaction pooling)
DATABASE_URL=postgres://controlplane:REPLACE_ME@127.0.0.1:5432/controlplane

# firecracker-containerd
CONTAINERD_ADDRESS=/run/firecracker-containerd/containerd.sock
SNAPSHOTTER=devmapper
FC_RUNTIME=aws.firecracker

# platform networking
GATEWAY_IP=172.20.0.1
PGBOUNCER_PORT=6432
BASE_DOMAIN=wess.dev
